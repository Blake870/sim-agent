# sim-agent configuration.
# Copy to `.env` and fill in. The agent reads `.env` from this directory on startup.

# Base URL of the sim server (no trailing slash).
AGENT_SERVER_URL=https://sim.gudoguy.com

# One-time pairing code from the sim panel ("Pair machine"). Only needed for first-run
# pairing — the issued token is then saved to agent-state.json. Leave blank to enter the
# code interactively when prompted.
AGENT_PAIRING_CODE=

# Idle poll interval in milliseconds. Default 10000 (10s).
AGENT_POLL_INTERVAL_MS=10000

# Demo mode: when 1, the agent invents a local `example` task instead of talking to the
# server (no pairing needed) — handy for testing the loop.
AGENT_DEMO=0

# Optional: override where the agent stores its state (token, machine id).
# AGENT_STATE_PATH=/var/lib/sim-agent/state.json
